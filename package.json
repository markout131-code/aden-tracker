{
  "name": "aden-tracker",
  "version": "1.5.8",
  "description": "Lineage 2 Event Tracker",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "deploy": "node scripts/release.js"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4"
  },
  "dependencies": {
    "firebase": "^12.11.0",
    "electron-updater": "^6.1.7"
  },
  "build": {
    "appId": "com.aden.tracker",
    "productName": "Aden Tracker",
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "markout131-code",
      "repo": "aden-tracker",
      "private": false,
      "releaseType": "release"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "icon.ico",
      "publish": [
        "github"
      ],
      "signingHashAlgorithms": [
        "sha256"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Aden Tracker"
    }
  }
}
